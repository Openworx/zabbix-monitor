<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <EditText
            android:id="@+id/srv_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/server_name_hint"
            android:inputType="text"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/srv_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/cfg_url_hint"
            android:inputType="textUri"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/srv_token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/cfg_token_hint"
            android:inputType="textPassword"
            android:importantForAutofill="no" />

        <CheckBox
            android:id="@+id/srv_ignore_ssl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cfg_ignore_ssl" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="16dp">

            <Button
                android:id="@+id/srv_test"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/cfg_test" />

            <Button
                android:id="@+id/srv_save"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/cfg_save" />
        </LinearLayout>

        <Button
            android:id="@+id/srv_delete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/server_delete" />

        <TextView
            android:id="@+id/srv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
